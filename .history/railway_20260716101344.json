{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python -m pip install -r backend/requirements.txt",
    "environment": {
      "PYTHON_VERSION": "3.11"
    }
  },
  "deploy": {
    "startCommand": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}