{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python3 -m pip install -r backend/requirements.txt"
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "environment": {
      "PYTHON_VERSION": "3.11"
    }
  }
}